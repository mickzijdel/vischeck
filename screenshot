#!/usr/bin/env python3
"""
Take an authenticated screenshot of a page on a local development server.

Usage:
  screenshot /connections
  screenshot /connections --dark
  screenshot /connections --width 375 --height 812
  screenshot /connections --full-page
  screenshot /admin/users -o tmp/screenshots/custom.png
  screenshot /dashboard --port 8000 --auth-url "/dev-login?token=secret&next={path}"

The script authenticates via a dev auth bypass route, navigates to the
target page, and saves a screenshot to tmp/screenshots/ in the current
working directory.
"""

import argparse
import os
import socket
import sys
from datetime import datetime
from pathlib import Path


def check_server(host, port):
    try:
        sock = socket.create_connection((host, port), timeout=2)
        sock.close()
        return True
    except (socket.timeout, ConnectionRefusedError, OSError):
        return False


def main():
    parser = argparse.ArgumentParser(description="Authenticated screenshot of a local dev page")
    parser.add_argument("path", help="URL path to screenshot, e.g. /connections")
    parser.add_argument("--dark", action="store_true", help="Use dark color scheme")
    parser.add_argument("--width", type=int, default=1280, help="Viewport width (default: 1280)")
    parser.add_argument("--height", type=int, default=720, help="Viewport height (default: 720)")
    parser.add_argument("--full-page", action="store_true", help="Capture full scrollable page")
    parser.add_argument("--output", "-o", help="Custom output path")
    parser.add_argument("--host", default="localhost", help="Dev server host (default: localhost)")
    parser.add_argument("--port", type=int, default=3000, help="Dev server port (default: 3000)")
    parser.add_argument("--wait", type=int, default=1500, help="Wait ms after page load (default: 1500)")
    parser.add_argument(
        "--auth-url",
        default="/dev_auth/login?token={token}&redirect_to={path}",
        help="Auth URL template. Use {token} and {path} placeholders. "
             "(default: /dev_auth/login?token={token}&redirect_to={path})"
    )
    parser.add_argument("--no-auth", action="store_true", help="Skip authentication (for public pages)")
    args = parser.parse_args()

    if not check_server(args.host, args.port):
        print(f"ERROR: Dev server not running on {args.host}:{args.port}", file=sys.stderr)
        sys.exit(1)

    # Output to tmp/screenshots/ in the current working directory
    screenshots_dir = Path.cwd() / "tmp" / "screenshots"
    screenshots_dir.mkdir(parents=True, exist_ok=True)

    if args.output:
        output_path = Path(args.output)
        output_path.parent.mkdir(parents=True, exist_ok=True)
    else:
        safe_path = args.path.strip("/").replace("/", "_") or "root"
        mode = "_dark" if args.dark else ""
        size = f"_{args.width}x{args.height}" if (args.width != 1280 or args.height != 720) else ""
        ts = datetime.now().strftime("%Y%m%d_%H%M%S")
        output_path = screenshots_dir / f"{safe_path}{mode}{size}_{ts}.png"

    token = os.environ.get("DEV_AUTH_TOKEN", "claude-screenshot-token")
    base_url = f"http://{args.host}:{args.port}"

    try:
        from playwright.sync_api import sync_playwright
    except ImportError:
        print("ERROR: Playwright not installed.", file=sys.stderr)
        print("Install: pip install playwright && playwright install chromium", file=sys.stderr)
        sys.exit(1)

    target = args.path if args.path.startswith("/") else f"/{args.path}"

    if args.no_auth:
        nav_url = f"{base_url}{target}"
    else:
        auth_path = args.auth_url.format(token=token, path=target)
        nav_url = f"{base_url}{auth_path}"

    with sync_playwright() as p:
        browser = p.chromium.launch(headless=True)
        context = browser.new_context(
            viewport={"width": args.width, "height": args.height},
            color_scheme="dark" if args.dark else "light",
        )
        page = context.new_page()

        try:
            page.goto(nav_url, wait_until="networkidle", timeout=15000)
        except Exception as e:
            print(f"ERROR: Navigation failed: {e}", file=sys.stderr)
            browser.close()
            sys.exit(1)

        page.wait_for_timeout(args.wait)
        page.screenshot(path=str(output_path), full_page=args.full_page)
        browser.close()

    # Print path so Claude Code can Read the image
    print(str(output_path))


if __name__ == "__main__":
    main()
