#!/usr/bin/env python3
"""
Take an authenticated screenshot of a page on a local development server.

Usage:
  screenshot /connections
  screenshot /connections --dark
  screenshot /connections --width 375 --height 812
  screenshot /connections --full-page
  screenshot /admin/users -o tmp/screenshots/custom.png
  screenshot /dashboard --port 8000 --auth-url "/dev-login?token=secret&next={path}"

The script auto-detects whether the page needs authentication: it probes the
target first, and only routes through the dev auth bypass route if the target
redirects to a login page or returns 401/403. Screenshots are saved to
tmp/screenshots/ in the current working directory. It exits non-zero (while
still saving the image for inspection) if the captured page is an HTTP error
or an unresolved auth wall, so a bad capture is never reported as success.
"""

import argparse
import os
import re
import socket
import sys
from datetime import datetime
from pathlib import Path
from urllib.parse import urlparse


def check_server(host, port):
    try:
        sock = socket.create_connection((host, port), timeout=2)
        sock.close()
        return True
    except (socket.timeout, ConnectionRefusedError, OSError):
        return False


def norm(url_or_path):
    """Path component, with trailing slash and query/fragment stripped."""
    return urlparse(url_or_path).path.rstrip("/")


LOGIN_RE = re.compile(r"(login|signin|sign_in|session|/auth/)", re.IGNORECASE)


def looks_like_login(url):
    """Soft heuristic used ONLY to phrase warning messages, never for control flow."""
    return bool(LOGIN_RE.search(urlparse(url).path))


def navigate(page, url):
    """Navigate and return (status, final_url). status is None for same-document navs."""
    resp = page.goto(url, wait_until="networkidle", timeout=15000)
    status = resp.status if resp else None
    return status, page.url


def main():
    parser = argparse.ArgumentParser(description="Authenticated screenshot of a local dev page")
    parser.add_argument("path", help="URL path to screenshot, e.g. /connections")
    parser.add_argument("--dark", action="store_true", help="Use dark color scheme")
    parser.add_argument("--width", type=int, default=1280, help="Viewport width (default: 1280)")
    parser.add_argument("--height", type=int, default=720, help="Viewport height (default: 720)")
    parser.add_argument("--full-page", action="store_true", help="Capture full scrollable page")
    parser.add_argument("--output", "-o", help="Custom output path")
    parser.add_argument("--host", default="localhost", help="Dev server host (default: localhost)")
    parser.add_argument("--port", type=int, default=3000, help="Dev server port (default: 3000)")
    parser.add_argument("--wait", type=int, default=1500, help="Wait ms after page load (default: 1500)")
    parser.add_argument(
        "--auth-url",
        default="/dev_auth/login?token={token}&redirect_to={path}",
        help="Auth URL template. Use {token} and {path} placeholders. "
             "(default: /dev_auth/login?token={token}&redirect_to={path})"
    )
    parser.add_argument("--no-auth", action="store_true", help="Skip authentication (for public pages)")
    args = parser.parse_args()

    if not check_server(args.host, args.port):
        print(f"ERROR: Dev server not running on {args.host}:{args.port}", file=sys.stderr)
        sys.exit(1)

    # Output to tmp/screenshots/ in the current working directory
    screenshots_dir = Path.cwd() / "tmp" / "screenshots"
    screenshots_dir.mkdir(parents=True, exist_ok=True)

    if args.output:
        output_path = Path(args.output)
        output_path.parent.mkdir(parents=True, exist_ok=True)
    else:
        safe_path = args.path.strip("/").replace("/", "_") or "root"
        mode = "_dark" if args.dark else ""
        size = f"_{args.width}x{args.height}" if (args.width != 1280 or args.height != 720) else ""
        ts = datetime.now().strftime("%Y%m%d_%H%M%S")
        output_path = screenshots_dir / f"{safe_path}{mode}{size}_{ts}.png"

    token = os.environ.get("DEV_AUTH_TOKEN", "claude-screenshot-token")
    base_url = f"http://{args.host}:{args.port}"

    try:
        from playwright.sync_api import sync_playwright
    except ImportError:
        print("ERROR: Playwright not installed.", file=sys.stderr)
        print("Install: pip install playwright && playwright install chromium", file=sys.stderr)
        sys.exit(1)

    target = args.path if args.path.startswith("/") else f"/{args.path}"
    target_url = f"{base_url}{target}"
    auth_path = args.auth_url.format(token=token, path=target)
    auth_url = f"{base_url}{auth_path}"

    def is_status_error(status):
        return status is not None and status >= 400

    def on_target(status, final_url):
        return not is_status_error(status) and norm(final_url) == norm(target)

    with sync_playwright() as p:
        browser = p.chromium.launch(headless=True)
        context = browser.new_context(
            viewport={"width": args.width, "height": args.height},
            color_scheme="dark" if args.dark else "light",
        )
        page = context.new_page()

        exit_code = 0
        try:
            if args.no_auth:
                # Explicit override: navigate the target directly, no auth dance.
                status, final_url = navigate(page, target_url)
            else:
                # Auto-detect: probe the target WITHOUT auth first. For public pages
                # this single navigation is also the one we screenshot.
                status, final_url = navigate(page, target_url)

                redirected_away = norm(final_url) != norm(target)
                auth_required = status in (401, 403) or redirected_away

                if on_target(status, final_url):
                    print(f"NOTE: captured {target} (no auth needed)", file=sys.stderr)
                elif not auth_required:
                    # Stayed on the target but it returned a non-auth error (404, 500…).
                    # Not an auth wall — let the final check report the HTTP error.
                    pass
                else:
                    # Auth appears required. Attempt the auth bypass route.
                    status, final_url = navigate(page, auth_url)

                    if status == 404 and norm(final_url) == norm(auth_path):
                        # The auth route itself doesn't exist.
                        print(
                            f"ERROR: {target} requires auth but the auth route "
                            f"{norm(auth_path)} returned 404.\n"
                            f"       Run the vischeck:setup-auth skill to add a dev auth "
                            f"route, or pass --no-auth if this page is meant to be public.",
                            file=sys.stderr,
                        )
                        exit_code = 1
                    elif on_target(status, final_url):
                        print(f"NOTE: captured {target} (authenticated)", file=sys.stderr)
                    else:
                        # Still not on target after authenticating.
                        hint = (
                            " (looks like a login page)" if looks_like_login(final_url) else ""
                        )
                        print(
                            f"WARNING: still redirected to {final_url}{hint} after "
                            f"authenticating — the token may be wrong or the auth route "
                            f"broken. Try the vischeck:setup-auth skill.",
                            file=sys.stderr,
                        )
                        exit_code = 1
        except Exception as e:
            print(f"ERROR: Navigation failed: {e}", file=sys.stderr)
            browser.close()
            sys.exit(1)

        # Final check: never report a clean success for an HTTP error page.
        if is_status_error(status) and exit_code == 0:
            print(
                f"ERROR: {final_url} returned HTTP {status} — screenshot saved for "
                f"inspection but the capture is not a healthy page.",
                file=sys.stderr,
            )
            exit_code = 1

        page.wait_for_timeout(args.wait)
        page.screenshot(path=str(output_path), full_page=args.full_page)
        browser.close()

    # Print path so Claude Code can Read the image
    print(str(output_path))
    sys.exit(exit_code)


if __name__ == "__main__":
    main()
