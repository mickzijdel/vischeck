// dev-env standard (dev-hooks:dev-env-setup) — version tracked via DEV_ENV_VERSION in mise.toml.
// For shell-heavy repos and Claude Code plugins (hooks/scripts/*.sh, bin/*, *.py).
amends "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
    ["shellcheck"] = Builtins.shellcheck
    ["shfmt"] = Builtins.shfmt
    ["ruff-check"] {
        glob = "**/*.py"
        check = "ruff check --force-exclude {{ files }}"
        fix = "ruff check --force-exclude --fix {{ files }}"
    }
    ["ruff-format"] {
        glob = "**/*.py"
        check = "ruff format --force-exclude --diff {{ files }}"
        fix = "ruff format --force-exclude {{ files }}"
    }
    // --- Extensionless scripts (bin/foo, hooks) ----------------------------------
    // CC-plugin / script repos keep their executables extensionless so they run as
    // bare commands, so the *.sh / *.py globs above never match them. These companion
    // steps detect such scripts by SHEBANG instead (same trick the `vulture` check
    // step uses), so shellcheck/shfmt/ruff cover them with no per-repo glob editing.
    // They carry no glob (so hk runs them whenever anything is staged) and ignore
    // {{ files }} — the inner `git ls-files | grep -l` picks the real targets, and
    // `xargs -r` no-ops when there are none (a repo with no extensionless scripts is
    // unaffected). check-only by design: auto-fixing would need an explicit `stage`
    // glob that extensionless paths can't express cleanly, so a flagged script is
    // fixed by hand (or `ruff check --fix` / `shfmt -w`). They run full-tree, not
    // incremental — fine for the handful of scripts such a repo carries.
    ["shellcheck-scripts"] {
        check = "git ls-files ':!*.sh' ':!*.bash' | while IFS= read -r f; do head -n1 \"$f\" 2>/dev/null | grep -qE '^#!.*\\b(ba)?sh\\b' && printf '%s\\n' \"$f\"; done | xargs -r shellcheck"
    }
    ["shfmt-scripts"] {
        check = "git ls-files ':!*.sh' ':!*.bash' ':!*.mksh' ':!*.bats' ':!*.zsh' | while IFS= read -r f; do head -n1 \"$f\" 2>/dev/null | grep -qE '^#!.*\\b(ba)?sh\\b' && printf '%s\\n' \"$f\"; done | xargs -r shfmt -d"
    }
    ["ruff-check-scripts"] {
        check = "git ls-files ':!*.py' ':!*.pyi' | while IFS= read -r f; do head -n1 \"$f\" 2>/dev/null | grep -qE '^#!.*(python|uv run)' && printf '%s\\n' \"$f\"; done | xargs -r ruff check --force-exclude"
    }
    ["ruff-format-scripts"] {
        check = "git ls-files ':!*.py' ':!*.pyi' | while IFS= read -r f; do head -n1 \"$f\" 2>/dev/null | grep -qE '^#!.*(python|uv run)' && printf '%s\\n' \"$f\"; done | xargs -r ruff format --force-exclude --diff"
    }
    // Shipped scripts must carry the executable bit IN THE GIT INDEX (mode 100755):
    // with core.fileMode=false a local chmod +x never reaches git, so clones and
    // plugin-cache installs get scripts that die with exit 126 "Permission denied".
    // Detects scripts by shebang (line 1 only, same trick as the steps above) among
    // 100644-mode index entries. Single awk on purpose: hk's internal `sh` chokes on
    // a while/read loop inside $() (kills the script at the assignment even when the
    // substitution exits 0), so keep every intermediate command zero-exit. CI's lint
    // job enforces the same rule (see ci.<stack>.yml), so the gates can't drift.
    ["exec-bit-scripts"] {
        check = "bad=$(git ls-files -s | awk -F'\\t' '$1 ~ /^100644/ { if ((getline line < $2) > 0 && line ~ /^#!/) print $2; close($2) }'); if [ -n \"$bad\" ]; then echo 'Shebang scripts missing the executable bit in the git index. Fix: git update-index --chmod=+x <file>'; echo \"$bad\"; exit 1; fi"
    }
    // --- Audits (dead-code + duplication) ---------------------------------------
    // These run on pre-commit too (not just `check`/CI): vulture is ~0.15s and jscpd
    // ~0.7s warm (well under a second each), so catching dead code / clones before push
    // is worth the cost.
    // Both carry a glob, so they only fire when a matching file is staged (a docs-only
    // commit skips them). They scan the whole tree, not just {{ files }}.
    // Dead code. Scans `.` (all *.py, excluding .venv/build) plus any extensionless
    // tracked file with a python/uv shebang (PEP 723 CLIs like bin/screenshot).
    ["vulture"] {
        glob = "**/*.py"
        check = "uvx vulture --min-confidence 80 --exclude '*/.venv/*,.venv,build,dist' . $(git ls-files ':!*.py' | while IFS= read -r f; do head -n1 \"$f\" 2>/dev/null | grep -qE '^#!.*(python|uv run)' && printf '%s\\n' \"$f\"; done)"
    }
    // Duplication. jscpd 5.x via npx; config in `.jscpd.json`. `-f` scopes to code formats
    // (no config equivalent) so docs/yaml aren't flagged. (See SKILL.md › jscpd note.)
    // The version-cooldown policy (latest on a 4-day cooldown, floored at v5) and the
    // offline fallback live in scripts/run-jscpd.sh, shared with the CI audit job so the
    // local and CI gates can't drift.
    ["jscpd"] {
        glob = List("**/*.sh", "**/*.py")
        check = "bash scripts/run-jscpd.sh python,bash"
    }
    // GitHub Actions workflow linter — schema/expression/`needs:` correctness that SHA-pinning
    // and zizmor don't cover (typo'd keys, bad ${{ }} refs, undefined job deps). hk builtin,
    // glob-gated to .github/workflows/*.yml|yaml; needs `actionlint` from mise (mise.toml).
    // `-shellcheck=` turns OFF actionlint's shellcheck-of-`run:` pass: our run: blocks
    // deliberately word-split (`shellcheck $files`) which trips SC2086, and real *.sh files are
    // already covered by the dedicated shellcheck step.
    ["actionlint"] = (Builtins.actionlint) {
        check = "actionlint -shellcheck= {{ files }}"
    }
    // GitHub Actions security static analysis. hk builtin — globs .github/workflows/*.yml,
    // .github/dependabot.yml and **/action.yml, so it only fires when a workflow/action file
    // is staged. Flags credential persistence, template injection, over-broad GITHUB_TOKEN
    // permissions, etc. (see the github-actions skill). Needs `zizmor` from mise (mise.toml).
    ["zizmor"] = Builtins.zizmor
    // Secret scanning (defense-in-depth alongside fnox). hk builtin.
    ["gitleaks"] = Builtins.gitleaks
    // Block accidentally-committed large files. hk builtin.
    ["check-added-large-files"] = Builtins.check_added_large_files
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = linters
    }
    ["fix"] {
        fix = true
        steps = linters
    }
    // `check` is the full suite CI runs. The audits (vulture, jscpd) now live in `linters`,
    // so they already run on pre-commit; `check` is just the same set under one name.
    ["check"] {
        steps = linters
    }
}
